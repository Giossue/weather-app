# Used by docker-compose.yml for local Docker runs.
# Do not commit a real .env with production secrets.

# OpenWeather One Call API 4.0 key. Required for real weather data.
OPENWEATHER_API_KEY=replace-with-your-openweather-key
OPENWEATHER_BASE_URL=https://api.openweathermap.org

# Local Docker public URLs.
WEB_PORT=8080
CORS_ORIGIN=http://localhost:8080
# Leave blank to use same-origin /api through Nginx. Use an absolute URL only if API is on another domain.
VITE_API_BASE_URL=

# PostgreSQL container.
POSTGRES_DB=weather_app
POSTGRES_USER=weather_app
POSTGRES_PASSWORD=weather_app
POSTGRES_PORT=5432
DATABASE_URL=postgresql://weather_app:weather_app@postgres:5432/weather_app

# App behavior.
WEATHER_CACHE_TTL_SECONDS=1800
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
DEFAULT_LANGUAGE=es
DEFAULT_UNITS=metric
