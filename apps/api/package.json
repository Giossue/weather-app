{
  "name": "@weather-app/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir=dist",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src/tests",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun src/db/migrate.ts"
  },
  "dependencies": {
    "@weather-app/config": "workspace:*",
    "@weather-app/contracts": "workspace:*",
    "@weather-app/db": "workspace:*",
    "@weather-app/shared": "workspace:*",
    "drizzle-orm": "^0.44.6",
    "hono": "^4.9.10",
    "postgres": "^3.4.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.7",
    "typescript": "^5.9.3"
  }
}
